# Browser-safe (RLS-enforced).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# Operational config.
ERROR_EMAIL_RECIPIENT=
COUNCIL_CRITIC_RISK_THRESHOLD=medium   # low | medium | high
COUNCIL_TOKEN_CAP_DAILY=500000         # per-user daily token cap ([CD PICK])
COUNCIL_BETA_ALLOWLIST=                # comma-separated emails for F04
ADMIN_EMAIL=                           # who can see /admin/metrics (F26). comma-separated emails. single-user v0.4 → just the CD
